/* ============================================================
   Header
   ============================================================ */

.header {
  position: fixed;
  inset: 0 0 auto 0;
  height: var(--header-height);
  display: flex;
  align-items: center;
  z-index: 1000;
  color: var(--color-white);
  background: rgba(6, 27, 51, 0.32);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  transition:
    background var(--transition-base),
    color var(--transition-base),
    border-color var(--transition-base),
    box-shadow var(--transition-base);
}

.header--scrolled {
  color: var(--color-navy-900);
  background: rgba(255, 255, 255, 0.92);
  border-bottom-color: rgba(6, 27, 51, 0.08);
  box-shadow: var(--shadow-soft);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  width: 100%;
}

.logo {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  text-decoration: none;
}

.logo__image {
  height: 38px;
  width: auto;
  display: none;
}

/* Dark header: show white wordmark */
.logo__image--dark {
  display: block;
}

/* Scrolled (light header): show blue wordmark */
.header--scrolled .logo__image--dark {
  display: none;
}

.header--scrolled .logo__image--light {
  display: block;
}

.header__actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
}

.nav__cta {
  display: none;
}

/* ============================================================
   Navigation
   ============================================================ */

.nav {
  position: fixed;
  top: var(--header-height);
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  background: linear-gradient(165deg, var(--color-navy-900), var(--color-navy-950));
  color: var(--color-white);
  transform: translateX(100%);
  visibility: hidden;
  transition:
    transform 0.35s ease,
    visibility 0.35s ease;
  z-index: 999;
}

.nav--open {
  transform: translateX(0);
  visibility: visible;
}

.nav__list {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav__link {
  display: inline-block;
  color: inherit;
  font-size: 1.25rem;
  font-weight: 500;
  text-decoration: none;
  position: relative;
  padding-bottom: 0.2rem;
  transition: color var(--transition-base);
}

.nav__link::after {
  content: '';
  position: absolute;
  left: 0;
  right: 100%;
  bottom: 0;
  height: 2px;
  background: var(--color-gold-500);
  transition: right var(--transition-base);
}

.nav__link:hover {
  color: var(--color-gold-300);
}

.nav__link:hover::after {
  right: 0;
}

/* ============================================================
   Mobile menu toggle
   ============================================================ */

.menu-toggle {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
  width: 32px;
  height: 24px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  z-index: 1100;
  color: inherit;
}

.menu-toggle__bar {
  display: block;
  width: 100%;
  height: 2px;
  border-radius: 2px;
  background: currentColor;
  transition:
    transform var(--transition-base),
    opacity var(--transition-base);
}

.menu-toggle--active .menu-toggle__bar:nth-child(1) {
  transform: translateY(8px) rotate(45deg);
}

.menu-toggle--active .menu-toggle__bar:nth-child(2) {
  opacity: 0;
}

.menu-toggle--active .menu-toggle__bar:nth-child(3) {
  transform: translateY(-8px) rotate(-45deg);
}

/* ============================================================
   Hero
   ============================================================ */

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding-top: var(--header-height);
  overflow: hidden;
  color: var(--color-white);
  background:
    radial-gradient(circle at 78% 20%, rgba(201, 154, 75, 0.18), transparent 52%),
    linear-gradient(160deg, var(--color-navy-950) 0%, var(--color-navy-900) 45%, var(--color-navy-800) 100%);
}

.hero__decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
}

.glow--top {
  width: 26rem;
  height: 26rem;
  top: -8rem;
  right: -6rem;
  background: var(--color-gold-500);
  opacity: 0.16;
}

.glow--bottom {
  width: 22rem;
  height: 22rem;
  bottom: -9rem;
  left: -5rem;
  background: var(--color-gold-500);
  opacity: 0.12;
}

.bean {
  position: absolute;
  border-radius: 50% / 60%;
  background: linear-gradient(135deg, var(--color-gold-500), var(--color-gold-300));
  opacity: 0.14;
}

.bean--1 {
  width: 70px;
  height: 100px;
  top: 18%;
  left: 6%;
  transform: rotate(-25deg);
}

.bean--2 {
  width: 50px;
  height: 74px;
  top: 68%;
  left: 16%;
  transform: rotate(15deg);
  opacity: 0.08;
}

.ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(201, 154, 75, 0.22);
}

.ring--1 {
  width: 260px;
  height: 260px;
  top: 8%;
  right: 6%;
}

.ring--2 {
  width: 160px;
  height: 160px;
  bottom: 6%;
  left: 4%;
  border-color: rgba(255, 255, 255, 0.1);
}

.hero__grid {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 3rem;
  align-items: center;
  padding-block: 4rem;
}

.hero__content {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  max-width: 560px;
}

.hero__eyebrow {
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-gold-300);
}

.hero__title {
  font-size: clamp(3rem, 11vw, 5.5rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-cream-100);
}

.hero__slogan {
  font-family: var(--font-heading);
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-style: italic;
  color: var(--color-gold-300);
}

.hero__text {
  max-width: 56ch;
  font-size: 1.05rem;
  color: var(--color-cream-muted);
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 0.5rem;
}

/* Hero product mosaic */

.hero__visual {
  position: relative;
}

.hero__mosaic {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.625rem;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: var(--border-gold);
  box-shadow: var(--shadow-lift);
  background: var(--color-navy-800);
}

.hero__mosaic-item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}

.hero__mosaic-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.hero__mosaic-item:hover .hero__mosaic-image {
  transform: scale(1.06);
}

.hero__mosaic-tag {
  position: absolute;
  bottom: 1.25rem;
  left: 1.25rem;
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: var(--border-gold);
  background: rgba(2, 20, 44, 0.6);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  color: var(--color-gold-300);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* Brand background (large, faded) — hero decor */
.hero__brand-bg {
  position: absolute;
  right: 1rem;
  bottom: -2rem;
  width: clamp(220px, 28vw, 380px);
  height: auto;
  opacity: 0.06;
  pointer-events: none;
  user-select: none;
}

/* Mascote floating over the product mosaic */
.hero__mascote {
  position: absolute;
  bottom: -1rem;
  right: -1.25rem;
  width: clamp(72px, 12vw, 110px);
  height: auto;
  filter: drop-shadow(0 8px 20px rgba(2, 20, 44, 0.55));
  z-index: 3;
  pointer-events: none;
}

@media (min-width: 1024px) {
  .hero__grid {
    grid-template-columns: 1.1fr 0.9fr;
  }
}

/* ============================================================
   Product cards — dark variant (used on dark sections)
   ============================================================ */

.product-card {
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: var(--border-gold);
  box-shadow: var(--shadow-soft);
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base);
  background: rgba(255, 255, 255, 0.04);
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lift);
}

.product-card--dark {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(201, 154, 75, 0.25);
  color: var(--color-cream-100);
}

.product-card__img-wrap {
  position: relative;
  aspect-ratio: 3 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.25rem;
  overflow: hidden;
  background: var(--color-navy-800);
}

.product-card__img-wrap--square {
  aspect-ratio: 1;
  padding: 0.875rem;
}

.product-card__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.product-card:hover .product-card__img {
  transform: scale(1.04);
}

.product-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  padding: 1.25rem;
  flex: 1;
}

.product-card__name {
  font-size: 1.15rem;
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-cream-100);
}

.product-card__name--sm {
  font-size: 1rem;
}

.product-card__desc {
  font-size: 0.9rem;
  color: var(--color-cream-muted);
  flex: 1;
}

.product-card__desc--sm {
  font-size: 0.85rem;
  -webkit-line-clamp: 2;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-top: auto;
  padding-top: 0.5rem;
  border-top: 1px solid rgba(201, 154, 75, 0.2);
}

.product-card__price {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-gold-300);
  white-space: nowrap;
}

/* Intensity indicator */

.intensity {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.intensity__dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.intensity__dot--filled {
  background: var(--color-gold-500);
}

.intensity__label {
  margin-left: 0.35rem;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-cream-muted);
}

/* ============================================================
   Outros produtos — responsive grid (8 items)
   ============================================================ */

.products-grid {
  display: grid;
  gap: 1.25rem;
  grid-template-columns: 1fr;
}

@media (min-width: 480px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 768px) {
  .products-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1024px) {
  .products-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.product-card--compact .product-card__body {
  padding: 1rem;
}

/* ============================================================
   Edition cards
   ============================================================ */

.edition-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: var(--border-gold);
  box-shadow: var(--shadow-soft);
  background: var(--color-white);
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base);
}

.edition-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lift);
}

.edition-card__badge {
  position: absolute;
  top: 1rem;
  right: 0;
  padding: 0.3rem 1rem 0.3rem 1.25rem;
  border-radius: 999px 0 0 999px;
  background: linear-gradient(135deg, var(--color-gold-500), var(--color-gold-300));
  color: var(--color-navy-900);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  box-shadow: var(--shadow-soft);
  z-index: 2;
}

.edition-card__img-wrap {
  aspect-ratio: 3 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.25rem;
  overflow: hidden;
  background: var(--color-cream-100);
}

.edition-card__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.edition-card:hover .edition-card__img {
  transform: scale(1.03);
}

.edition-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  padding: 1.25rem;
  flex: 1;
}

.edition-card__name {
  font-size: 1.1rem;
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-navy-900);
}

.edition-card__desc {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  flex: 1;
}

.edition-card__cta {
  align-self: flex-start;
  margin-top: auto;
}

/* ============================================================
   QR Code section
   ============================================================ */

.qr-layout {
  display: grid;
  gap: 3rem;
  align-items: center;
}

.qr-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
}

.qr-frame {
  padding: 1.25rem;
  border-radius: var(--radius-lg);
  border: var(--border-gold);
  box-shadow: var(--shadow-lift);
  background: var(--color-white);
}

.qr-img {
  width: 200px;
  height: 200px;
  border-radius: 8px;
}

.qr-label {
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.qr-steps {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.qr-step {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: var(--color-white);
  border: 1px solid rgba(6, 27, 51, 0.05);
  border-left: 3px solid var(--color-gold-500);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
}

.qr-step__num {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-gold-500), var(--color-gold-300));
  color: var(--color-navy-900);
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.95rem;
  box-shadow: var(--shadow-soft);
}

.qr-step__content {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.qr-step__title {
  font-size: 1rem;
  font-family: var(--font-heading);
  font-weight: 600;
  color: var(--color-navy-900);
}

.qr-step__desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
}

@media (min-width: 768px) {
  .qr-layout {
    grid-template-columns: auto 1fr;
  }
}

/* ============================================================
   Cafeteria menu
   ============================================================ */

.cafeteria-menu {
  max-width: 760px;
  margin-inline: auto;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.cafe-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.1rem 1.5rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-md);
  transition:
    transform var(--transition-base),
    border-color var(--transition-base),
    background var(--transition-base);
}

.cafe-item:hover {
  transform: translateX(6px);
  border-color: rgba(201, 154, 75, 0.4);
  background: rgba(255, 255, 255, 0.08);
}

.cafe-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.cafe-item__name {
  font-size: 1.05rem;
  color: var(--color-cream-100);
}

.cafe-item__desc {
  font-size: 0.88rem;
  color: var(--color-cream-muted);
}

.cafe-item__price {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-gold-300);
  white-space: nowrap;
}

.cafeteria-menu__cta {
  margin-top: 1rem;
  display: flex;
  justify-content: center;
}

/* ============================================================
   Diferenciais — 3+2 centered layout on desktop
   ============================================================ */

.differentials-grid {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: 1fr;
}

@media (min-width: 640px) {
  .differentials-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .differentials-grid {
    /* 6-column virtual grid — row 1: 3 items × 2cols; row 2: 2 items centered */
    grid-template-columns: repeat(6, 1fr);
  }

  .differentials-grid > .differential:nth-child(1) { grid-column: 1 / 3; }
  .differentials-grid > .differential:nth-child(2) { grid-column: 3 / 5; }
  .differentials-grid > .differential:nth-child(3) { grid-column: 5 / 7; }
  .differentials-grid > .differential:nth-child(4) { grid-column: 2 / 4; }
  .differentials-grid > .differential:nth-child(5) { grid-column: 4 / 6; }
}

.differential {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  padding: 1.75rem 1.25rem;
  border-radius: var(--radius-md);
  text-align: center;
  border: 1px solid transparent;
  transition:
    transform var(--transition-base),
    background var(--transition-base),
    border-color var(--transition-base);
}

.differential:hover {
  transform: translateY(-4px);
  background: var(--color-cream-100);
  border-color: rgba(201, 154, 75, 0.25);
}

.differential__icon {
  font-size: 2rem;
  line-height: 1;
}

.differential__title {
  font-size: 1rem;
  font-weight: 700;
}

.differential__text {
  font-size: 0.88rem;
  color: var(--color-text-muted);
}

/* ============================================================
   Contato
   ============================================================ */

.contact {
  display: grid;
  gap: 1.25rem;
  grid-template-columns: 1fr;
  max-width: 760px;
  margin-inline: auto;
}

@media (min-width: 640px) {
  .contact {
    grid-template-columns: repeat(3, 1fr);
  }
}

.contact__card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem;
  background: var(--color-white);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
  color: var(--color-text);
  text-decoration: none;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base),
    border-color var(--transition-base);
}

.contact__card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lift);
  border-color: var(--color-gold-500);
}

.contact__icon {
  font-size: 1.75rem;
}

.contact__info {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.contact__label {
  font-weight: 600;
  color: var(--color-navy-900);
  font-size: 0.95rem;
}

.contact__value {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  word-break: break-word;
}

/* ============================================================
   Footer
   ============================================================ */

.footer {
  padding-block: 3rem;
  text-align: center;
  background: var(--color-navy-950);
  color: var(--color-cream-muted);
}

.footer__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.footer__brand {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
}

.footer__logo {
  height: 36px;
  width: auto;
  opacity: 0.9;
}

.footer__slogan {
  font-style: italic;
  color: var(--color-gold-300);
}

.footer__copy {
  font-size: 0.85rem;
  opacity: 0.7;
}

/* ============================================================
   Large screens: nav switches to inline bar
   ============================================================ */

@media (min-width: 640px) {
  .logo__image--dark,
  .logo__image--light {
    height: 42px;
  }
}

@media (min-width: 1024px) {
  .logo__image--dark,
  .logo__image--light {
    height: 48px;
  }

  .nav {
    position: static;
    inset: auto;
    transform: none;
    visibility: visible;
    flex-direction: row;
    justify-content: center;
    flex: 1;
    background: none;
    color: inherit;
  }

  .nav__list {
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 1.5rem;
  }

  .nav__link {
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .menu-toggle {
    display: none;
  }
}

