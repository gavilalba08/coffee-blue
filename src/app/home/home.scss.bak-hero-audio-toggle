/* === Seção CEOs / Cofundadores === */

.section--ceos {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 10%, rgba(217, 174, 89, 0.12), transparent 28%),
    linear-gradient(180deg, var(--color-navy-950), var(--color-navy-900));
  color: var(--color-cream-100);
}

.section--ceos .section__header h2 {
  color: var(--color-cream-100);
}

.section--ceos .section__header p {
  color: rgba(245, 240, 229, 0.78);
}

.ceos__stage {
  position: relative;
  max-width: 1060px;
  min-height: 560px;
  margin: 3rem auto 0;
  border: 1px solid rgba(217, 174, 89, 0.24);
  border-radius: 2rem;
  background: rgba(2, 20, 44, 0.46);
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.28);
  overflow: hidden;
  cursor: default;
}

.ceos__mosaic {
  display: grid;
  grid-template-columns: 1.05fr 0.86fr 0.72fr;
  grid-template-rows: repeat(6, 82px);
  gap: 0.85rem;
  height: 100%;
  min-height: 560px;
  padding: 1rem;
}

.ceos__card {
  position: relative;
  overflow: hidden;
  border: 0;
  border-radius: 1.4rem;
  background: rgba(255, 255, 255, 0.05);
  cursor: pointer;
  box-shadow: inset 0 0 0 1px rgba(217, 174, 89, 0.18);
  transform: translateY(0);
  transition:
    transform 260ms ease,
    box-shadow 260ms ease,
    filter 260ms ease;
}

.ceos__card:hover,
.ceos__card:focus-visible {
  transform: translateY(-5px);
  box-shadow:
    inset 0 0 0 1px rgba(217, 174, 89, 0.55),
    0 20px 50px rgba(0, 0, 0, 0.32);
  filter: saturate(1.08);
  outline: none;
}

.ceos__card:nth-child(1) {
  grid-row: span 6;
}

.ceos__card:nth-child(2) {
  grid-row: span 3;
}

.ceos__card:nth-child(3) {
  grid-row: span 3;
}

.ceos__card:nth-child(4) {
  grid-row: span 3;
}

.ceos__card:nth-child(5) {
  grid-column: span 2;
  grid-row: span 3;
}

.ceos__card img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform 420ms ease;
}

.ceos__card:hover img,
.ceos__card:focus-visible img {
  transform: scale(1.045);
}

.ceos__card-overlay {
  position: absolute;
  inset-inline: 0;
  bottom: 0;
  display: grid;
  gap: 0.18rem;
  padding: 1.15rem;
  text-align: left;
  background: linear-gradient(180deg, transparent, rgba(2, 20, 44, 0.92));
  color: var(--color-cream-100);
}

.ceos__card-overlay small {
  color: var(--color-gold-300);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.ceos__card-overlay strong {
  font-family: var(--font-display);
  font-size: clamp(1.05rem, 2vw, 1.55rem);
  line-height: 1.05;
}

.ceos__detail {
  display: grid;
  grid-template-columns: minmax(280px, 0.92fr) minmax(320px, 1.08fr);
  gap: 0;
  min-height: 560px;
  animation: ceoStageIn 420ms ease both;
}

.ceos__portrait-expanded {
  position: relative;
  min-height: 560px;
  margin: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  animation: ceoPhotoSlide 520ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.ceos__portrait-expanded::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(2, 20, 44, 0.12), transparent 52%),
    linear-gradient(180deg, transparent 58%, rgba(2, 20, 44, 0.42));
  pointer-events: none;
}

.ceos__portrait-expanded img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.ceos__bio {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 560px;
  padding: clamp(2rem, 4vw, 4rem);
  background:
    radial-gradient(circle at 88% 12%, rgba(217, 174, 89, 0.16), transparent 30%),
    rgba(255, 255, 255, 0.04);
  animation: ceoTextReveal 540ms ease 80ms both;
}

.ceos__close {
  position: absolute;
  top: 1.2rem;
  right: 1.2rem;
  width: 44px;
  height: 44px;
  border: 1px solid rgba(217, 174, 89, 0.36);
  border-radius: 999px;
  background: rgba(2, 20, 44, 0.54);
  color: var(--color-cream-100);
  font-size: 1.7rem;
  line-height: 1;
  cursor: pointer;
}

.ceos__label {
  color: var(--color-gold-300);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.ceos__bio h3 {
  margin: 0.7rem 0 0.15rem;
  color: var(--color-cream-100);
  font-family: var(--font-display);
  font-size: clamp(2.1rem, 4.8vw, 4.4rem);
  line-height: 0.95;
}

.ceos__bio strong {
  color: var(--color-gold-300);
  font-family: var(--font-display);
  font-size: clamp(1.25rem, 2.2vw, 2rem);
  font-style: italic;
}

.ceos__bio h4 {
  margin: 1rem 0 1.3rem;
  color: rgba(245, 240, 229, 0.92);
  font-size: clamp(1rem, 1.4vw, 1.2rem);
}

.ceos__bio p {
  max-width: 58ch;
  margin: 0;
  color: rgba(245, 240, 229, 0.78);
  font-size: 1rem;
  line-height: 1.85;
}

.ceos__temperament {
  display: inline-grid;
  gap: 0.2rem;
  align-self: flex-start;
  margin-top: 1.6rem;
  padding: 0.85rem 1rem;
  border: 1px solid rgba(217, 174, 89, 0.32);
  border-radius: 1rem;
  background: rgba(2, 20, 44, 0.35);
}

.ceos__temperament span {
  color: rgba(245, 240, 229, 0.62);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

.ceos__temperament b {
  color: var(--color-gold-300);
}

@keyframes ceoPhotoSlide {
  from {
    opacity: 0;
    transform: translateX(26%) scale(0.94);
  }

  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

@keyframes ceoTextReveal {
  from {
    opacity: 0;
    transform: translateX(24px);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
