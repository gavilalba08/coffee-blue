<a class="skip-link" href="#main-content">Pular para o conteúdo principal</a>

<header class="header" [class.header--scrolled]="isScrolled()">
  <div class="container header__inner">
    <a class="logo" href="#hero" (click)="goToAnchor('#hero', $event)">

          <img
            class="logo__image logo__image--dark"
            src="assets/brand/header-logo-white.png"
            alt="Blue Coffee"
          />
          <img
            class="logo__image logo__image--light"
            src="assets/brand/header-logo-blue.png"
            alt="Blue Coffee"
          />
</a>

    <nav
      class="nav"
      [class.nav--open]="isMenuOpen()"
      id="primary-navigation"
      aria-label="Navegação principal"
    >
      <ul class="nav__list">
        @for (link of navLinks; track link.label) {
          <li class="nav__item">
            @if (link.routerLink) {
              <a class="nav__link" [routerLink]="link.routerLink" (click)="closeMenu()">{{
                link.label
              }}</a>
            } @else {
              <a class="nav__link" [href]="link.href" (click)="goToAnchor(link.href, $event)">{{ link.label }}</a>
            }
          </li>
        }
      </ul>
    </nav>

    <div class="header__actions">
      <a class="btn btn--gold btn--sm nav__cta" routerLink="/cardapiodigital" (click)="closeMenu()">
        Cardápio Digital
      </a>

      <button
        type="button"
        class="menu-toggle"
        [class.menu-toggle--active]="isMenuOpen()"
        (click)="toggleMenu()"
        [attr.aria-expanded]="isMenuOpen()"
        aria-controls="primary-navigation"
        aria-label="Abrir menu de navegação"
      >
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
      </button>
    </div>
  </div>
</header>

<main id="main-content">
  <!-- Hero -->
  <section id="hero" class="hero">
    <div class="hero__decor" aria-hidden="true">
      <span class="glow glow--top"></span>
      <span class="glow glow--bottom"></span>
      <span class="ring ring--1"></span>
      <span class="ring ring--2"></span>
      <img
        ngSrc="assets/brand/logo-blue-coffee-com-mascote-branca-cropped.png"
        width="600"
        height="400"
        class="hero__brand-bg"
        alt=""
      />
    </div>

    <div class="container hero__grid">
      <div class="hero__content">
        <p class="hero__eyebrow reveal">Torrefação artesanal &amp; curadoria premium</p>
        <h1 class="hero__title reveal">Blue Coffee</h1>
        <p class="hero__slogan reveal">Mais que café, uma experiência.</p>
        <p class="hero__text reveal">
          Da escolha dos grãos à xícara na sua mesa, criamos blends exclusivos e momentos
          inesquecíveis. Uma linha completa de cafés, edições especiais e produtos para quem vive o
          café como um ritual.
        </p>
        <div class="hero__actions reveal">
          <a class="btn btn--gold" href="#cafes-classicos">Conheça nossos cafés</a>
          <a class="btn btn--ghost" routerLink="/cardapiodigital">Peça pelo cardápio digital</a>
        </div>
      </div>

      <div class="hero__video-frame reveal" aria-label="Vídeo institucional Blue Coffee">
                <video id="hero-video" class="hero-video" autoplay muted loop playsinline preload="metadata">
          <source src="assets/videos/blue-coffee-hero-video-web.mp4" type="video/mp4" />
          Seu navegador não suporta vídeos HTML5.
        </video>
        <button
          class="hero-video-audio"
          type="button"
          (click)="toggleHeroVideoAudio()"
          [attr.aria-label]="isHeroVideoMuted() ? 'Ativar som do vídeo' : 'Silenciar vídeo'"
        >
          <span aria-hidden="true">{{ isHeroVideoMuted() ? '🔇' : '🔊' }}</span>
          <strong>{{ isHeroVideoMuted() ? 'Ativar som' : 'Silenciar' }}</strong>
        </button>

        <div class="hero__video-badge">Blue Coffee Experience</div>
      </div>
    </div>
  </section>

  <section class="section section--ceos ceos ceos--horizontal" id="ceos">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__eyebrow">Quem faz acontecer</span>
        <h2>CEOs da Blue Coffee</h2>
        <p>
          Conheça a equipe que participou da criação da marca, dos produtos e da experiência Blue Coffee.
        </p>
      </div>

      <div class="ceos__stage">
        @if (selectedCeo(); as member) {
          <button
            class="ceos__backdrop"
            type="button"
            aria-label="Fechar apresentação"
            (click)="closeCeo()"
          ></button>

          <article
            class="ceos__detail"
            [class.ceos__detail--reverse]="member.detailImageSide === 'right'"
            (click)="$event.stopPropagation()"
          >
            <button
              class="ceos__close"
              type="button"
              aria-label="Fechar apresentação"
              (click)="closeCeo()"
            >
              ×
            </button>

            <div class="ceos__detail-media">
              <img
                [src]="member.image"
                [alt]="member.name"
                [style.object-position]="member.previewPosition"
              />
            </div>

            <div class="ceos__detail-copy">
              <span class="ceos__eyebrow">{{ member.nickname }}</span>
              <h3 class="ceos__name">{{ member.name }}</h3>
              <p class="ceos__role">{{ member.role }}</p>
              <p class="ceos__description">{{ member.description }}</p>
              <p class="ceos__temperament">
                <span>Temperamento:</span>
                <strong>{{ member.temperament }}</strong>
              </p>
            </div>
          </article>
        } @else {
          <div class="ceos__strip" aria-label="Mosaico horizontal dos CEOs da Blue Coffee">
            @for (member of ceoMembers; track member.name; let i = $index) {
              <button
                class="ceos__tile"
                type="button"
                [class.ceos__tile--center]="i === 2"
                (click)="selectCeo(member)"
              >
                <img
                  [src]="member.image"
                  [alt]="member.name"
                  [style.object-position]="member.previewPosition"
                  loading="lazy"
                />

                <span class="ceos__tile-overlay">
                  <small>{{ member.nickname }}</small>
                  <strong>{{ member.name }}</strong>
                </span>
              </button>
            }
          </div>
        }
      </div>
    </div>
  </section>



  <!-- Nossos Cafés -->
  <section id="cafes" class="section section--dark">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Linha Tradicional</p>
        <h2 class="section__title">Nossos Cafés</h2>
        <p class="section__subtitle">
          Quatro blends desenvolvidos para cada momento do seu dia, do mais suave ao mais intenso.
        </p>
      </div>

      <div class="grid grid--4">
        @for (coffee of classicCoffees; track coffee.name) {
          <article class="product-card product-card--dark reveal">
            <div class="product-card__img-wrap">
              <img
                [ngSrc]="coffee.image"
                width="600"
                height="600"
                [alt]="coffee.name"
                class="product-card__img"
              />
            </div>
            <div class="product-card__body">
              <h3 class="product-card__name">{{ coffee.name }}</h3>
              <p class="product-card__desc">{{ coffee.description }}</p>
              <div
                class="intensity"
                role="img"
              >
                @for (level of intensityLevels; track level) {
                  <span
                    class="intensity__dot"
                    [class.intensity__dot--filled]="level <= coffee.intensity"
                  ></span>
                }
                <span class="intensity__label">Intensidade</span>
              </div>
              <div class="product-card__footer">
                <span class="product-card__price">{{ coffee.price }}</span>
                <a class="btn btn--outline-gold btn--sm" routerLink="/cardapiodigital">
                  Ver no cardápio
                </a>
              </div>
            </div>
          </article>
        }
      </div>
    </div>
  </section>

  <!-- Edições Especiais -->
  <section id="edicoes" class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Coleções limitadas</p>
        <h2 class="section__title">Edições Especiais</h2>
        <p class="section__subtitle">
          Blends únicos criados para celebrar as datas mais marcantes do ano.
        </p>
      </div>

      <div class="grid grid--4">
        @for (edition of specialEditions; track edition.name) {
          <article class="edition-card reveal">
            <span class="edition-card__badge">{{ edition.badge }}</span>
            <div class="edition-card__img-wrap">
              <img
                [ngSrc]="edition.image"
                width="600"
                height="600"
                [alt]="edition.name"
                class="edition-card__img"
              />
            </div>
            <div class="edition-card__body">
              <h3 class="edition-card__name">{{ edition.name }}</h3>
              <p class="edition-card__desc">{{ edition.description }}</p>
              <a class="btn btn--gold btn--sm edition-card__cta" routerLink="/cardapiodigital">
                Ver no cardápio
              </a>
            </div>
          </article>
        }
      </div>
    </div>
  </section>

  <!-- Outros Produtos -->
  <section id="produtos" class="section section--dark">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Além do café</p>
        <h2 class="section__title">Outros Produtos</h2>
        <p class="section__subtitle">
          Uma seleção completa para levar a experiência Blue Coffee para casa.
        </p>
      </div>

      <div class="products-grid reveal">
        @for (product of otherProducts; track product.name) {
          <article class="product-card product-card--dark product-card--compact">
            <div class="product-card__img-wrap product-card__img-wrap--square">
              <img
                [ngSrc]="product.image"
                width="600"
                height="600"
                [alt]="product.name"
                class="product-card__img"
              />
            </div>
            <div class="product-card__body">
              <h3 class="product-card__name product-card__name--sm">{{ product.name }}</h3>
              <p class="product-card__desc product-card__desc--sm">{{ product.description }}</p>
              <div class="product-card__footer">
                <span class="product-card__price">{{ product.price }}</span>
                <a class="btn btn--outline-gold btn--sm" routerLink="/cardapiodigital">
                  Adicionar ao pedido
                </a>
              </div>
            </div>
          </article>
        }
      </div>
    </div>
  </section>

  <!-- Cardápio Digital + QR Code -->
  <section id="cardapio-digital" class="section">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Peça pelo celular</p>
        <h2 class="section__title">Cardápio Digital Blue Coffee</h2>
        <p class="section__subtitle">
          Escaneie o QR Code, escolha seus produtos e finalize o pedido diretamente pelo celular.
        </p>
      </div>

      <div class="qr-layout">
        <div class="qr-code-box reveal">
          <div class="qr-frame">
            <img
              ngSrc="assets/qr/qr-cardapio-digital.png"
              width="280"
              height="280"
              alt="QR Code do Cardápio Digital Blue Coffee"
              class="qr-img"
            />
          </div>
          <p class="qr-label">Escaneie para acessar</p>
          <a class="btn btn--gold" routerLink="/cardapiodigital">Acessar Cardápio Digital</a>
        </div>

        <ol class="qr-steps reveal" aria-label="Como usar o cardápio digital">
          @for (step of cardapioSteps; track step.number) {
            <li class="qr-step">
              <span class="qr-step__num" aria-hidden="true">{{ step.number }}</span>
              <div class="qr-step__content">
                <h3 class="qr-step__title">{{ step.title }}</h3>
                <p class="qr-step__desc">{{ step.description }}</p>
              </div>
            </li>
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Cafeteria -->
  <section id="cafeteria" class="section section--dark">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Visite-nos</p>
        <h2 class="section__title">Cafeteria</h2>
        <p class="section__subtitle">
          Um espaço acolhedor para saborear nossos cafés e delícias preparadas com cuidado.
        </p>
      </div>

      <div class="cafeteria-menu reveal">
        @for (item of menuItems; track item.name) {
          <div class="cafe-item">
            <div class="cafe-item__info">
              <h3 class="cafe-item__name">{{ item.name }}</h3>
              <p class="cafe-item__desc">{{ item.description }}</p>
            </div>
            <span class="cafe-item__price">{{ item.price }}</span>
          </div>
        }
        <div class="cafeteria-menu__cta">
          <a class="btn btn--gold" routerLink="/cardapiodigital">Acessar Cardápio Digital</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Diferenciais -->
  <section id="diferenciais" class="section">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__eyebrow">Por que Blue Coffee</p>
        <h2 class="section__title">Diferenciais</h2>
        <p class="section__subtitle">O que torna a experiência Blue Coffee única do início ao fim.</p>
      </div>

      <div class="differentials-grid">
        @for (item of differentials; track item.title) {
          <article class="differential reveal">
            <span class="differential__icon" aria-hidden="true">{{ item.icon }}</span>
            <h3 class="differential__title">{{ item.title }}</h3>
            <p class="differential__text">{{ item.description }}</p>
          </article>
        }
      </div>
    </div>
  </section>

  <!-- Contato -->
  <section id="contato" class="section section--alt">
    <div class="container">
      <div class="section__header">
        <span class="eyebrow">FALE COM A GENTE</span>
        <h2>Redes Sociais &amp; Contato</h2>
        <p>Estamos por perto — siga, mande mensagem ou envie um e-mail.</p>
      </div>

      <div class="contact-cards-center" aria-label="Redes sociais e contato da Blue Coffee">
        <a
          class="contact-card-center"
          href="https://www.instagram.com/coffeee_blue?utm_source=qr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Abrir Instagram da Blue Coffee"
        >
          <span class="contact-card-center__icon">📸</span>
          <span class="contact-card-center__content">
            <strong>Instagram</strong>
            <small>@coffeee_blue</small>
          </span>
        </a>

        <a
          class="contact-card-center"
          href="mailto:contato@coffeeblue.com.br"
          aria-label="Enviar e-mail para a Blue Coffee"
        >
          <span class="contact-card-center__icon">✉️</span>
          <span class="contact-card-center__content">
            <strong>E-mail</strong>
            <small>contato@coffeeblue.com.br</small>
          </span>
        </a>
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="container footer__inner">
    <a class="footer__brand" routerLink="/">
      <img
        ngSrc="assets/brand/wordmark-blue-coffee-branca-cropped.png"
        width="480"
        height="120"
        class="footer__logo"
        alt="Blue Coffee"
      />
    </a>
    <p class="footer__slogan">Blue Coffee — Mais que café, uma experiência.</p>
    <p class="footer__copy">© 2026 Blue Coffee. Todos os direitos reservados.</p>
  </div>
</footer>


<button
  class="to-top-rabbit"
  type="button"
  aria-label="Voltar ao topo da página"
  title="Voltar ao topo"
  (click)="scrollToTop()"
>
  <img src="assets/designs/coffee-blue-design-06.png" alt="" aria-hidden="true" />
</button>

