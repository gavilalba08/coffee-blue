/* ============================================================
   Cardápio Digital page
   ============================================================ */

.cp-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-cream-100);
}

/* ============================================================
   Confirmation screen
   ============================================================ */

.cp-confirmed {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  background: linear-gradient(160deg, var(--color-navy-950), var(--color-navy-900));
}

.cp-confirmed__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  text-align: center;
  max-width: 480px;
}

.cp-confirmed__mascote {
  width: clamp(80px, 20vw, 140px);
  height: auto;
  filter: drop-shadow(0 12px 24px rgba(2, 20, 44, 0.5));
}

.cp-confirmed__title {
  font-size: 2rem;
  color: var(--color-cream-100);
}

.cp-confirmed__text {
  font-size: 1.05rem;
  color: var(--color-cream-muted);
  max-width: 38ch;
}

/* ============================================================
   Header
   ============================================================ */

.cp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.875rem 1.25rem;
  background: var(--color-navy-950);
  border-bottom: var(--border-gold);
  position: sticky;
  top: 0;
  z-index: 100;
}

.cp-header__brand {
  display: flex;
  align-items: center;
  text-decoration: none;
}

.cp-header__wordmark {
  height: 28px;
  width: auto;
}

.cp-header__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.cp-header__subtitle {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gold-300);
}

.cp-header__mascote {
  height: 42px;
  width: auto;
  filter: drop-shadow(0 2px 8px rgba(2, 20, 44, 0.5));
}

/* ============================================================
   Categories
   ============================================================ */

.cp-categories {
  display: flex;
  gap: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  background: var(--color-navy-900);
  border-bottom: var(--border-gold);
  padding: 0;
}

.cp-categories::-webkit-scrollbar {
  display: none;
}

.cp-cat-btn {
  flex-shrink: 0;
  padding: 0.875rem 1.25rem;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  color: var(--color-cream-muted);
  font-size: 0.88rem;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition:
    color var(--transition-base),
    border-color var(--transition-base),
    background var(--transition-base);
}

.cp-cat-btn:hover {
  color: var(--color-cream-100);
  background: rgba(255, 255, 255, 0.05);
}

.cp-cat-btn--active {
  color: var(--color-gold-300);
  border-bottom-color: var(--color-gold-500);
  background: rgba(201, 154, 75, 0.06);
}

/* ============================================================
   Layout: products + cart sidebar
   ============================================================ */

.cp-layout {
  display: grid;
  flex: 1;
  grid-template-columns: 1fr;
  align-items: start;
  padding: 1.25rem;
  gap: 1.5rem;
  max-width: 1280px;
  margin-inline: auto;
  width: 100%;
}

@media (min-width: 960px) {
  .cp-layout {
    grid-template-columns: 1fr 340px;
    padding: 2rem;
    gap: 2rem;
  }
}

/* ============================================================
   Products grid
   ============================================================ */

.cp-products {
  min-width: 0;
}

.cp-products__grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: 1fr;
}

@media (min-width: 480px) {
  .cp-products__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 768px) and (max-width: 959px) {
  .cp-products__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 960px) {
  .cp-products__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1200px) {
  .cp-products__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.cp-product-card {
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-white);
  border: 1px solid rgba(6, 27, 51, 0.06);
  box-shadow: var(--shadow-soft);
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base);
}

.cp-product-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lift);
}

.cp-product-card__img-wrap {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem;
  overflow: hidden;
  background: var(--color-cream-100);
}

.cp-product-card__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}

.cp-product-card:hover .cp-product-card__img {
  transform: scale(1.03);
}

.cp-product-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding: 0.875rem;
  flex: 1;
}

.cp-product-card__name {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--color-navy-900);
}

.cp-product-card__desc {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  flex: 1;
  -webkit-line-clamp: 2;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cp-product-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-top: 0.5rem;
  padding-top: 0.625rem;
  border-top: 1px solid rgba(6, 27, 51, 0.06);
}

.cp-product-card__price {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--color-blue-600);
}

/* ============================================================
   Quantity control
   ============================================================ */

.cp-qty {
  display: flex;
  align-items: center;
  gap: 0;
  border-radius: 999px;
  border: 1px solid rgba(6, 27, 51, 0.12);
  overflow: hidden;
}

.cp-qty__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  background: none;
  border: none;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-navy-900);
  cursor: pointer;
  transition: background var(--transition-base);
}

.cp-qty__btn:hover:not(:disabled) {
  background: rgba(6, 27, 51, 0.06);
}

.cp-qty__btn:disabled {
  color: rgba(6, 27, 51, 0.25);
  cursor: not-allowed;
}

.cp-qty__btn--add {
  background: var(--color-navy-900);
  color: var(--color-cream-100);
}

.cp-qty__btn--add:hover {
  background: var(--color-blue-600) !important;
}

.cp-qty__value {
  min-width: 1.75rem;
  text-align: center;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-navy-900);
}

/* ============================================================
   Cart sidebar
   ============================================================ */

.cp-cart {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  border: var(--border-gold);
  box-shadow: var(--shadow-soft);
  padding: 1.5rem;
  position: sticky;
  top: 4rem;
}

@media (max-width: 959px) {
  .cp-cart {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    border-bottom: none;
    box-shadow: 0 -8px 32px rgba(2, 20, 44, 0.2);
    max-height: 70vh;
    overflow-y: auto;
    z-index: 200;
    padding-bottom: calc(1.5rem + env(safe-area-inset-bottom));
  }
}

.cp-cart__title {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-navy-900);
  padding-bottom: 0.75rem;
  border-bottom: var(--border-gold);
}

.cp-cart__list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.cp-cart__item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 0.75rem;
  font-size: 0.88rem;
}

.cp-cart__item-name {
  color: var(--color-text);
  flex: 1;
}

.cp-cart__item-price {
  color: var(--color-blue-600);
  font-weight: 600;
  white-space: nowrap;
}

.cp-cart__total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: var(--color-navy-900);
  border-radius: var(--radius-md);
  color: var(--color-cream-100);
  font-weight: 700;
  font-size: 1rem;
}

.cp-cart__total span:last-child {
  color: var(--color-gold-300);
  font-family: var(--font-heading);
  font-size: 1.1rem;
}

.cp-cart__phone {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.cp-cart__phone-label {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.cp-cart__phone-input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid rgba(6, 27, 51, 0.15);
  border-radius: var(--radius-md);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-navy-900);
  background: var(--color-cream-100);
  transition: border-color var(--transition-base);
}

.cp-cart__phone-input:focus {
  outline: none;
  border-color: var(--color-gold-500);
  box-shadow: 0 0 0 3px rgba(201, 154, 75, 0.2);
}

.cp-cart__finalize {
  width: 100%;
  padding: 0.9rem;
}

.cp-cart__hint {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  text-align: center;
  margin: 0;
}

/* Extra bottom padding on mobile when cart is fixed — fixed safe value */

@media (max-width: 959px) {
  .cp-layout {
    padding-bottom: 420px;
  }
}

/* === Ajuste final das imagens no Cardápio Digital === */

.cp-product-card__img-wrap,
.product-card__image,
.menu-product__image,
.cardapio-product__image {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #f8f4ea, #e8edf6);
}

.cp-product-card__img,
.product-card__image img,
.menu-product__image img,
.cardapio-product__image img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center;
}

.cp-product-card__img-wrap {
  aspect-ratio: 4 / 3;
  padding: 0 !important;
}

.cp-product-card__img {
  object-fit: cover !important;
  object-position: center !important;
}

@media (max-width: 768px) {
  .cp-product-card__img-wrap {
    aspect-ratio: 1 / 1;
  }
}

/* === Override final: imagens inteiras no Cardápio Digital === */

.cp-product-card__img-wrap,
.product-card__image,
.menu-product__image,
.cardapio-product__image {
  background:
    radial-gradient(circle at 50% 30%, rgba(217, 174, 89, 0.12), transparent 34%),
    linear-gradient(180deg, #fffaf0, #edf3fb) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0.85rem !important;
  aspect-ratio: 1 / 1 !important;
}

.cp-product-card__img,
.product-card__image img,
.menu-product__image img,
.cardapio-product__image img {
  width: 100% !important;
  height: 100% !important;
  object-fit: contain !important;
  object-position: center !important;
}

/* === Cardápio Digital: produto limpo, sem moldura azul === */
.cp-product-card__img-wrap,
.product-card__image,
.menu-product__image,
.cardapio-product__image {
  background: transparent !important;
  border: 0 !important;
  box-shadow: none !important;
  padding: 1rem 1rem 0.5rem !important;
  aspect-ratio: 1 / 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: visible !important;
}

.cp-product-card__img,
.product-card__image img,
.menu-product__image img,
.cardapio-product__image img {
  width: 100% !important;
  height: 100% !important;
  max-width: 220px !important;
  max-height: 220px !important;
  object-fit: contain !important;
  object-position: center !important;
  filter: drop-shadow(0 18px 24px rgba(2, 20, 44, 0.18));
}

.cp-product-card {
  overflow: hidden;
}

@media (max-width: 768px) {
  .cp-product-card__img,
  .product-card__image img,
  .menu-product__image img,
  .cardapio-product__image img {
    max-width: 180px !important;
    max-height: 180px !important;
  }
}

